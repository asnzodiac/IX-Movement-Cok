<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#000000">
<title>AIX Security – COK</title>

<style>
:root{
  --bg:#fff;
  --text:#000;
  --header:#f4f4f4;
  --border:#555;
  --dark:#222;
  --green:#c8f7c5;
  --yellow:#fff3b0;
  --red:#f7c5c5;
}

*{box-sizing:border-box}

body{
  margin:0;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  background:var(--bg);
  color:var(--text);
  -webkit-text-size-adjust:100%;
}

/* TOP BAR */
.controls-bar{
  display:flex;
  justify-content:space-between;
  padding:10px;
  background:var(--header);
  border-bottom:2px solid var(--border);
  position:sticky;
  top:0;
  z-index:1000;
}

.btn{
  background:var(--dark);
  color:#fff;
  border:none;
  padding:8px 12px;
  border-radius:6px;
  font-size:13px;
  cursor:pointer;
}

/* TABS */
.tabs{
  display:flex;
  justify-content:center;
  gap:15px;
  padding:15px 0;
}

.tab-btn{
  border:2px solid var(--border);
  padding:10px 20px;
  border-radius:20px;
  background:#fff;
  opacity:.5;
  font-weight:600;
  cursor:pointer;
}

.tab-btn.active{
  opacity:1;
  background:var(--header);
}

/* SECTIONS */
.view-section{display:none;padding:0 10px}
.view-section.active{display:block}

/* TABLE */
h2{
  text-align:center;
  background:var(--header);
  padding:8px;
  border:2px solid var(--border);
}

table{
  width:100%;
  border-collapse:collapse;
  margin-bottom:25px;
  border:2px solid var(--border);
  display:block;
  overflow-x:auto;
  white-space:nowrap;
}

th,td{
  border:1px solid var(--border);
  padding:8px 6px;
  text-align:center;
  font-size:13px;
}

th{
  background:var(--dark);
  color:#fff;
}

.loading{
  text-align:center;
  padding:20px;
  font-weight:bold;
}

/* STATUS COLORS */
.onTime{background:var(--green)}
.delay{background:var(--yellow)}
.heavyDelay{background:var(--red)}

@media(max-width:768px){
  th,td{font-size:11px}
}
</style>
</head>
<body>

<div class="controls-bar">
  <button class="btn" onclick="loadAll()">Refresh</button>
</div>

<div class="tabs">
  <button class="tab-btn active" id="flightsTab">COK Flights</button>
  <button class="tab-btn" id="turnTab">Turnaround</button>
</div>

<div id="flights-section" class="view-section active">

  <h2>ARRIVALS – COK</h2>
  <table id="arrivals-table">
    <thead>
      <tr>
        <th>Flight</th>
        <th>Reg</th>
        <th>From</th>
        <th>ETA</th>
        <th>STA</th>
        <th>Aircraft</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <tr><td colspan="7" class="loading">Loading...</td></tr>
    </tbody>
  </table>

  <h2>DEPARTURES – COK</h2>
  <table id="departures-table">
    <thead>
      <tr>
        <th>Flight</th>
        <th>Reg</th>
        <th>To</th>
        <th>ETD</th>
        <th>STD</th>
        <th>Aircraft</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <tr><td colspan="7" class="loading">Loading...</td></tr>
    </tbody>
  </table>

</div>

<div id="turnarounds-section" class="view-section">
  <h2>TURNAROUND MATCHES – COK</h2>
  <table id="turn-table">
    <thead>
      <tr>
        <th>Flight Pair</th>
        <th>Reg</th>
        <th>From</th>
        <th>To</th>
        <th>Time</th>
        <th>Aircraft</th>
      </tr>
    </thead>
    <tbody>
      <tr><td colspan="6" class="loading">Waiting for data...</td></tr>
    </tbody>
  </table>
</div>

<script>
const AIRPORT="cok";
const baseUrl=`https://api.flightradar24.com/common/v1/airport.json?code=${AIRPORT}`;

const toTime=t=>t?new Date(t*1000).toLocaleTimeString("en-IN",{hour:"2-digit",minute:"2-digit",hour12:false,timeZone:"Asia/Kolkata"}):"-";

async function safeFetch(url){
  try{
    const res=await fetch(url);
    if(!res.ok)throw new Error();
    return await res.json();
  }catch{
    return null;
  }
}

async function loadFlights(type){
  const tbody=document.querySelector(`#${type}-table tbody`);
  tbody.innerHTML=`<tr><td colspan="7" class="loading">Loading...</td></tr>`;

  const ts=Math.floor(Date.now()/1000);
  const url=`${baseUrl}&plugin-setting[schedule][mode]=${type}&plugin-setting[schedule][timestamp]=${ts}&limit=60`;

  const data=await safeFetch(url);

  if(!data){
    tbody.innerHTML=`<tr><td colspan="7">⚠ Unable to load (Safari blocks API)</td></tr>`;
    return;
  }

  const flights=data?.result?.response?.airport?.pluginData?.schedule?.[type]?.data||[];

  if(!flights.length){
    tbody.innerHTML=`<tr><td colspan="7">No flights available</td></tr>`;
    return;
  }

  tbody.innerHTML="";

  flights.forEach(f=>{
    const fl=f.flight;
    const fn=fl?.identification?.number?.default||"-";
    const sch=type==="departures"?fl.time.scheduled?.departure:fl.time.scheduled?.arrival;
    const est=type==="departures"?fl.time.estimated?.departure:fl.time.estimated?.arrival;

    const tr=document.createElement("tr");
    tr.innerHTML=`
      <td>${fn}</td>
      <td>${fl.aircraft?.registration||"-"}</td>
      <td>${type==="departures"?(fl.airport.destination?.code?.iata||"-"):(fl.airport.origin?.code?.iata||"-")}</td>
      <td>${toTime(est)||toTime(sch)}</td>
      <td>${toTime(sch)}</td>
      <td>${fl.aircraft?.model?.text||"-"}</td>
      <td>${fl.status?.text||"-"}</td>
    `;
    tbody.appendChild(tr);
  });
}

async function loadAll(){
  await loadFlights("arrivals");
  await loadFlights("departures");
  buildTurnarounds();
}

function buildTurnarounds(){
  const arrRows=[...document.querySelector("#arrivals-table tbody").rows];
  const depRows=[...document.querySelector("#departures-table tbody").rows];
  const turnBody=document.querySelector("#turn-table tbody");

  const regMap={};

  arrRows.forEach(r=>{
    const reg=r.cells[1]?.textContent;
    if(!reg||reg=="-")return;
    regMap[reg]={arr:r};
  });

  depRows.forEach(r=>{
    const reg=r.cells[1]?.textContent;
    if(!reg||reg=="-")return;
    if(!regMap[reg])regMap[reg]={};
    regMap[reg].dep=r;
  });

  turnBody.innerHTML="";

  Object.keys(regMap).forEach(reg=>{
    if(regMap[reg].arr && regMap[reg].dep){
      const tr=document.createElement("tr");
      tr.innerHTML=`
        <td>${regMap[reg].arr.cells[0].textContent} / ${regMap[reg].dep.cells[0].textContent}</td>
        <td>${reg}</td>
        <td>${regMap[reg].arr.cells[2].textContent}</td>
        <td>${regMap[reg].dep.cells[2].textContent}</td>
        <td>${regMap[reg].arr.cells[3].textContent} / ${regMap[reg].dep.cells[3].textContent}</td>
        <td>${regMap[reg].arr.cells[5].textContent}</td>
      `;
      turnBody.appendChild(tr);
    }
  });

  if(!turnBody.innerHTML)
    turnBody.innerHTML=`<tr><td colspan="6">No turnarounds found</td></tr>`;
}

/* TAB SWITCH */
document.getElementById("flightsTab").onclick=()=>{
  document.getElementById("flights-section").classList.add("active");
  document.getElementById("turnarounds-section").classList.remove("active");
  document.getElementById("flightsTab").classList.add("active");
  document.getElementById("turnTab").classList.remove("active");
};

document.getElementById("turnTab").onclick=()=>{
  document.getElementById("flights-section").classList.remove("active");
  document.getElementById("turnarounds-section").classList.add("active");
  document.getElementById("turnTab").classList.add("active");
  document.getElementById("flightsTab").classList.remove("active");
};

loadAll();
setInterval(loadAll,60000);
</script>

</body>
</html>
