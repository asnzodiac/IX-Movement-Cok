<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#000000">
<title>AIX Security – COK</title>
<link rel="manifest" href="manifest.json" />

<style>
:root {
  --bg:#fff; --text:#000; --hdr:#f4f4f4; --th:#222; --tht:#fff;
  --green:#c8f7c5; --yellow:#fff3b0; --red:#f7c5c5; --grey:#eee;
  --border:#ccc;
  --font:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
}

[data-theme="dark"] {
  --bg:#121212; --text:#e0e0e0; --hdr:#1e1e1e; --th:#333; --tht:#fff;
  --green:#1f4d2b; --yellow:#5c4b00; --red:#5c1f1f; --grey:#333;
  --border:#444;
}

*{box-sizing:border-box}
body{
  margin:0;
  background:var(--bg);
  color:var(--text);
  font-family:var(--font);
  font-size:13px;
}

/* CONTROLS */
.controls-bar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:10px;
  background:var(--hdr);
  border-bottom:1px solid var(--border);
  position:sticky; top:0; z-index:1000;
}
.btn{
  background:var(--th); color:var(--tht);
  border:none;
  padding:8px 12px;
  border-radius:4px;
  font-weight:bold;
  font-size:0.8rem;
  cursor:pointer;
}

/* STATUS BAR */
#status-bar {
  text-align:center;
  padding:4px;
  font-size:0.75rem;
  background:var(--bg);
  border-bottom:1px solid var(--border);
  color:var(--text);
  opacity:0.7;
}

/* TABS */
.tabs{
  display:flex;
  justify-content:center;
  gap:10px;
  padding:15px 0;
}
.tab-btn{
  background:transparent;
  color:var(--text);
  border:1px solid var(--border);
  padding:8px 16px;
  border-radius:20px;
  font-size:0.9rem;
  font-weight:bold;
  cursor:pointer;
  opacity:0.6;
}
.tab-btn.active{
  border-color:var(--text);
  background:var(--hdr);
  opacity:1;
}

/* SECTIONS */
.view-section{display:none;padding:0 5px}
.view-section.active{display:block}

.split-view{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}
.split-col{
  flex:1;
  min-width:100%; /* Stack on mobile by default */
}
@media(min-width: 768px) {
  .split-col{min-width:45%}
}

h2{
  text-align:center;
  margin:10px 0 5px 0;
  font-size:1rem;
  background:var(--hdr);
  padding:8px;
  border:1px solid var(--border);
  text-transform:uppercase;
  letter-spacing:1px;
}

/* TABLES */
table{
  width:100%;
  border-collapse:collapse;
  margin-bottom:30px;
  border:1px solid var(--border);
}
th,td{
  padding:8px 4px;
  border:1px solid var(--border);
  text-align:center;
  white-space:nowrap;
}
th{
  background:var(--th);
  color:var(--tht);
  position:sticky;
  top:55px; /* Adjust based on top bar height */
  z-index:900;
  font-size:0.75rem;
}
.flight-logo{height:14px;vertical-align:middle;margin-right:4px;display:inline-block}

/* COLORS */
.onTime{background:var(--green);color:#000!important}
.delay{background:var(--yellow);color:#000!important}
.heavyDelay{background:var(--red);color:#000!important}
.cancelled{background:var(--grey);color:#000!important;text-decoration:line-through}

</style>
</head>
<body>

<div class="controls-bar">
  <button class="btn" id="loadEarlierBtn">Earlier</button>
  <button class="btn" id="notifyBtn">🔔</button>
  <button class="btn" id="themeToggle">🌗</button>
</div>

<div id="status-bar">Waiting for data...</div>

<div class="tabs">
  <button class="tab-btn active" id="flightsTab">Flights</button>
  <button class="tab-btn" id="turnTab">Turnaround</button>
</div>

<div id="flights-section" class="view-section active">
  <div class="split-view">
    <div class="split-col">
      <h2>Arrivals</h2>
      <table id="arrivals-table">
        <thead>
          <tr>
            <th>Flt</th><th>Reg</th><th>From</th>
            <th>ETA</th><th>STA</th><th>Type</th><th>Stat</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
    <div class="split-col">
      <h2>Departures</h2>
      <table id="departures-table">
        <thead>
          <tr>
            <th>Flt</th><th>Reg</th><th>To</th>
            <th>ETD</th><th>STD</th><th>Type</th><th>Stat</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

<div id="turnarounds-section" class="view-section">
  <h2>Turnaround Matches</h2>
  <table id="turnarounds-table">
    <thead>
      <tr>
        <th>Pair</th><th>Reg</th><th>Route</th>
        <th>Time</th><th>Type</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>
</div>

<script>
/* ================= CONFIG ================= */
const AIRPORT = "cok";
const BRANDFETCH_CLIENT_ID = "1idBLQ1djCDndBUmUVs"; 

// --- ROBUST PROXY LIST ---
// We will try Proxy 1. If it fails, we try Proxy 2.
const PROXIES = [
    "https://api.allorigins.win/raw?url=",
    "https://api.codetabs.com/v1/proxy?quest="
];
const TARGET_URL = `https://api.flightradar24.com/common/v1/airport.json?code=${AIRPORT}`;

let baseTimestamp = Math.floor(Date.now() / 1000);
let loadedTimestamps = new Set();

/* ================= HELPERS ================= */
const statusDiv = document.getElementById("status-bar");
function setStatus(msg) { statusDiv.textContent = msg; }

// Dynamic Fetcher that rotates proxies
async function fetchWithFallback(targetUrl) {
    let lastError;
    for (const proxy of PROXIES) {
        try {
            const finalUrl = proxy + encodeURIComponent(targetUrl);
            console.log("Trying proxy:", proxy);
            const res = await fetch(finalUrl);
            if (!res.ok) throw new Error(`Status ${res.status}`);
            const data = await res.json();
            return data; // Success
        } catch (e) {
            console.warn("Proxy failed:", proxy, e);
            lastError = e;
        }
    }
    throw lastError; // All failed
}

const toTime = t => t ? new Date(t * 1000).toLocaleTimeString("en-IN", { timeZone: "Asia/Kolkata", hour: "2-digit", minute: "2-digit", hour12: false }) : "-";
const airlineAllowed = fn => ["IX","AK","FD","J9","UL","FZ"].some(a => fn.startsWith(a));

const getLogo = fn => {
  if (fn.startsWith("AK") || fn.startsWith("FD")) return "https://upload.wikimedia.org/wikipedia/commons/thumb/8/82/AirAsia_New_Logo_%282020%29.svg/768px-AirAsia_New_Logo_%282020%29.svg.png";
  
  let d = "";
  if (fn.startsWith("AI")) d="airindia.com";
  else if (fn.startsWith("IX")) d="airindiaexpress.com";
  else if (fn.startsWith("6E")) d="goindigo.in";
  else if (fn.startsWith("UK")) d="airvistara.com";
  else if (fn.startsWith("SG")) d="spicejet.com";
  else if (fn.startsWith("QP")) d="akasaair.com";
  else if (fn.startsWith("EK")) d="emirates.com";
  else if (fn.startsWith("EY")) d="etihad.com";
  else if (fn.startsWith("QR")) d="qatarairways.com";
  else if (fn.startsWith("G9")) d="airarabia.com";
  else if (fn.startsWith("FZ")) d="flydubai.com";
  else if (fn.startsWith("WY")) d="omanair.com";
  else if (fn.startsWith("KU")) d="kuwaitairways.com";
  else if (fn.startsWith("J9")) d="jazeeraairways.com";
  else if (fn.startsWith("UL")) d="srilankan.com";
  else if (fn.startsWith("MH")) d="malaysiaairlines.com";
  else if (fn.startsWith("TG")) d="thaiairways.com";
  else if (fn.startsWith("SQ")) d="singaporeair.com";
  else if (fn.startsWith("TR")) d="scoot.co";
  else if (fn.startsWith("SV")) d="saudia.com";
  else if (fn.startsWith("XY")) d="flynas.com";
  else if (fn.startsWith("NP")) d="flyadeal.com";
  else if (fn.startsWith("VJ")) d="vietjetair.com";
  else if (fn.startsWith("VN")) d="vietnamairlines.com";
  else if (fn.startsWith("OD")) d="batikair.com";
  else if (fn.startsWith("GF")) d="gulfair.com";
  
  if(!d) return "";
  return `https://cdn.brandfetch.io/${d}/logo.png?c=${BRANDFETCH_CLIENT_ID}&h=30`;
};

const delayMinutes = (sch, est) => sch && est ? Math.round((est - sch) / 60) : 0;
const rowClass = (status, delay) => {
  const s = status?.toLowerCase() || "";
  if (s.includes("cancel")) return "cancelled";
  if (delay > 45) return "heavyDelay";
  if (delay > 10) return "delay";
  return "onTime";
};
const withinTimeWindow = (type, sch, est, act) => {
  const now = Math.floor(Date.now() / 1000);
  const t = sch || est || 0;
  // Show flights from -2 hours ago to +24 hours ahead
  if (t < now - 7200 || t > now + 86400) return false;
  return true; 
};

/* ================= LOAD ================= */
async function loadFlights(type, ts, append = true) {
  if (loadedTimestamps.has(type + ts)) return;
  
  setStatus(`Loading ${type}...`);
  
  try {
    const url = `${TARGET_URL}&plugin-setting[schedule][mode]=${type}&plugin-setting[schedule][timestamp]=${ts}&limit=100`;
    
    // USE NEW ROBUST FETCHER
    const data = await fetchWithFallback(url);
    
    loadedTimestamps.add(type + ts);
    const flights = data?.result?.response?.airport?.pluginData?.schedule?.[type]?.data || [];
    const tbody = document.querySelector(`#${type}-table tbody`);
    if (!append) tbody.innerHTML = "";
    
    if (flights.length === 0) {
        console.log(`No ${type} data found.`);
    }

    flights.forEach(f => {
      const fl = f.flight;
      const fn = fl?.identification?.number?.default || "";
      if (!airlineAllowed(fn)) return;
      const isDep = type === "departures";
      const sch = isDep ? fl.time.scheduled?.departure : fl.time.scheduled?.arrival;
      const est = isDep ? fl.time.estimated?.departure : fl.time.estimated?.arrival;
      const act = isDep ? fl.time.actual?.departure : fl.time.actual?.arrival;
      
      if (!withinTimeWindow(type, sch, est, act)) return;
      
      const flightId = fl.identification?.id || fn;
      const existing = tbody.querySelector(`tr[data-flight-id="${flightId}"]`);
      const dly = delayMinutes(sch, est);
      const statusText = fl.status?.text || "-";
      const className = rowClass(statusText, dly);
      
      const rowHTML = `
        <td><img class="flight-logo" src="${getLogo(fn)}" onerror="this.style.display='none'">${fn}</td>
        <td>${fl.aircraft?.registration || "-"}</td>
        <td>${isDep ? (fl.airport.destination?.code?.iata || "-") : (fl.airport.origin?.code?.iata || "-")}</td>
        <td>${toTime(est) || toTime(sch)} ${dly > 0 ? `<br><small style='color:red'>(+${dly})</small>` : ""}</td>
        <td>${toTime(sch)}</td>
        <td>${fl.aircraft?.model?.code || "737"}</td>
        <td>${statusText}</td>`;

      if (existing) {
        existing.className = className;
        existing.innerHTML = rowHTML;
        existing.dataset.est = est || 0;
      } else {
        const tr = document.createElement("tr");
        tr.dataset.flightId = flightId;
        tr.dataset.sch = sch || 0;
        tr.dataset.est = est || 0;
        tr.className = className;
        tr.innerHTML = rowHTML;
        tbody.appendChild(tr);
      }
    });
    
    sortTable(`${type}-table`);
    setStatus("Data Updated: " + new Date().toLocaleTimeString());

  } catch (err) {
    console.error(`Failed to load ${type}:`, err);
    setStatus("Error loading data. Retrying...");
    // Remove from loaded set so we can retry later
    loadedTimestamps.delete(type+ts); 
  }
}

const sortTable = (tableId) => {
  const table = document.getElementById(tableId);
  const tbody = table.tBodies[0];
  const rows = Array.from(tbody.rows);
  rows.sort((a, b) => (parseInt(a.dataset.sch) || 0) - (parseInt(b.dataset.sch) || 0));
  rows.forEach(row => tbody.appendChild(row));
};

/* ================= TURNAROUNDS ================= */
function buildTurnarounds() {
  const arrivalsRows = Array.from(document.querySelector('#arrivals-table tbody').rows);
  const departuresRows = Array.from(document.querySelector('#departures-table tbody').rows);
  const regToArr = new Map();
  const regToDep = new Map();

  // Helper to extract data from row
  const getData = (row) => ({
      fn: row.cells[0].innerText.trim(),
      reg: row.cells[1].innerText.trim(),
      loc: row.cells[2].innerText.trim(),
      est: parseInt(row.dataset.est) || 0,
      sch: parseInt(row.dataset.sch) || 0,
      type: row.cells[5].innerText.trim()
  });

  arrivalsRows.forEach(row => {
    const d = getData(row);
    if (!d.reg || d.reg === '-') return;
    if (!regToArr.has(d.reg)) regToArr.set(d.reg, []);
    regToArr.get(d.reg).push(d);
  });

  departuresRows.forEach(row => {
    const d = getData(row);
    if (!d.reg || d.reg === '-') return;
    if (!regToDep.has(d.reg)) regToDep.set(d.reg, []);
    regToDep.get(d.reg).push(d);
  });

  const tbody = document.querySelector('#turnarounds-table tbody');
  tbody.innerHTML = '';

  for (const reg of regToArr.keys()) {
    if (!regToDep.has(reg)) continue;
    const arrs = regToArr.get(reg).sort((a,b)=>a.est-b.est);
    const deps = regToDep.get(reg).sort((a,b)=>a.est-b.est);

    for (const arr of arrs) {
      for (const dep of deps) {
        // Turnaround logic: Dep is after Arr, within 4 hours
        if (dep.est > arr.est && (dep.est - arr.est) < 14400) {
           const tr = document.createElement('tr');
           tr.innerHTML = `
             <td><b>${arr.fn}</b><br>⬇<br><b>${dep.fn}</b></td>
             <td>${reg}</td>
             <td>${arr.loc} -> ${dep.loc}</td>
             <td>ARR: ${toTime(arr.est)}<br>DEP: ${toTime(dep.est)}</td>
             <td>${arr.type}</td>
           `;
           tbody.appendChild(tr);
        }
      }
    }
  }
}

/* ================= INIT ================= */
async function loadAll() {
  baseTimestamp = Math.floor(Date.now() / 1000); 
  // Load current window + next 6 hours
  await loadFlights("arrivals", baseTimestamp);
  await loadFlights("departures", baseTimestamp);
  await loadFlights("arrivals", baseTimestamp + 21600);
  await loadFlights("departures", baseTimestamp + 21600);
  buildTurnarounds();
}

document.getElementById("loadEarlierBtn").onclick = async () => {
  baseTimestamp -= 21600; // -6 hours
  await loadFlights("arrivals", baseTimestamp);
  await loadFlights("departures", baseTimestamp);
  buildTurnarounds();
};

document.getElementById("themeToggle").onclick = () => {
  const html = document.documentElement;
  html.dataset.theme = html.dataset.theme === "dark" ? "light" : "dark";
};

// TAB SWITCHING
const sections = {
  flights: document.getElementById('flights-section'),
  turn: document.getElementById('turnarounds-section')
};
document.getElementById('flightsTab').onclick = () => {
    sections.flights.style.display='block';
    sections.turn.style.display='none';
    document.getElementById('flightsTab').classList.add('active');
    document.getElementById('turnTab').classList.remove('active');
};
document.getElementById('turnTab').onclick = () => {
    sections.flights.style.display='none';
    sections.turn.style.display='block';
    document.getElementById('flightsTab').classList.remove('active');
    document.getElementById('turnTab').classList.add('active');
};

// Start
loadAll();
setInterval(loadAll, 60000); // Refresh every min

</script>
</body>
</html>
